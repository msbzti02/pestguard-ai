# ==============================================================
# Department 2 — Environment Variables
# Deep Learning-Based Insect Pest Recognition System
# 6-Provider LLM Failover Chain
# ==============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# --- LLM Providers (at least one required for chatbot) ---
# The system tries providers in order. Add as many as you want
# for maximum reliability. All are FREE tier.

# Google Gemini (free): https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Groq (free): https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# OpenRouter (free models): https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Together AI (free tier): https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-key-here

# Cohere (free tier): https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-key-here

# Mistral AI (free tier): https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-key-here

# --- Weather API (optional, uses Open-Meteo without it) ---
OPENWEATHER_API_KEY=your-openweather-key-here

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
