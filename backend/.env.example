# ==============================================================
# Department 2 — Environment Variables
# Deep Learning-Based Insect Pest Recognition System
# ==============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# --- LLM Providers (at least one required for chatbot) ---
# Google Gemini (free): https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Groq (free): https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# --- Weather API (optional, uses mock without it) ---
# OpenWeatherMap (free): https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-key-here

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
